# Consumo — Synology Container Manager environment
#
# Copy this file to .env (same folder) and fill in real values.
# .env is gitignored — never commit real secrets.
#
# Container Manager auto-loads a file literally named .env from the
# project folder — no --env-file flag needed, no renaming required.

# ── InfluxDB ──────────────────────────────────────────────────────────────
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=change-me-strong-password
INFLUXDB_ORG=home
INFLUXDB_BUCKET=energy
INFLUXDB_TOKEN=change-me-long-random-token

# ── Grafana ───────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
GRAFANA_PORT=3000

# ── API ───────────────────────────────────────────────────────────────────
# Comma-separated list — add one key per client (web, sensor, scripts …)
API_KEYS=change-me-web-key,change-me-sensor-key

# ── Web ───────────────────────────────────────────────────────────────────
# Must match one of the API_KEYS above
API_KEY_WEB=change-me-web-key
SECRET_KEY=change-me-flask-secret

# ── Notification service ──────────────────────────────────────────────────
NTFY_URL=http://consumo-ntfy:80
NTFY_CHANNEL=consumo
TZ=Europe/Berlin
