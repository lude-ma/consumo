# Example environment variables for consumo.

# ── InfluxDB ──────────────────────────────────────────────────────────────
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=change-me-strong-password
INFLUXDB_ORG=home
INFLUXDB_BUCKET=energy
INFLUXDB_TOKEN=change-me-long-random-token

# ── Grafana ───────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# ── API ───────────────────────────────────────────────────────────────────
# Comma-separated list — add one key per client (web, sensor, scripts …)
API_KEYS=change-me-web-key,change-me-sensor-key

# ── Web ───────────────────────────────────────────────────────────────────
# Must match one of the API_KEYS above
API_KEY_WEB=change-me-web-key
SECRET_KEY=change-me-flask-secret
